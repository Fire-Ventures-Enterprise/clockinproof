{
  "name": "clockinproof",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --d1=clockinproof-production --local --ip 0.0.0.0 --port 3000",
    "build": "vite build && python scripts/escape-unicode.py",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist --project-name clockinproof",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:migrate:local": "wrangler d1 migrations apply clockinproof-production --local",
    "db:migrate:prod": "wrangler d1 migrations apply clockinproof-production",
    "db:seed": "wrangler d1 execute clockinproof-production --local --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed",
    "db:console": "wrangler d1 execute clockinproof-production --local"
  },
  "dependencies": {
    "hono": "^4.12.3"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}