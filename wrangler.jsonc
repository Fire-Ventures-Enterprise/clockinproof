{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "worktracker",
  "compatibility_date": "2026-02-27",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "worktracker-production",
      "database_id": "local-dev-placeholder"
    }
  ]
}
